{
    "compilerOptions": {
        "checkJs": true,
        "lib": ["dom", "dom.iterable", "esnext"],
        "strict": true,
        "types": ["./src/vite-env.d.ts"]
    },
    "tasks": {
        "dev": "deno run -A npm:vite@5",
        "build": "deno run -A npm:vite@5 build",
        "preview": "deno run -A npm:vite@5 preview",
        "serve": "deno run -A server.js",
        "check": "deno check --doc **/*.js",
        "lint": "deno lint src/",
        "test": "deno test src/",
        "format": "deno fmt",
        "ci": "deno task check && deno fmt --check && deno task lint && deno task test",
        "generate": "deno run -A scripts/generate-assets.js",
        "optimize": "deno run -A scripts/optimize-assets.js"
    },
    "imports": {
        "phaser": "npm:phaser@^3.86.0",
        "sharp": "npm:sharp@^0.34.5",
        "@google/genai": "npm:@google/genai@^1.49.0"
    },
    "exclude": [
        "dist/",
        "node_modules/",
        "vite.config.js",
        ".vite/",
        ".vera/"
    ],
    "fmt": {
        "useTabs": false,
        "lineWidth": 120,
        "indentWidth": 4,
        "semiColons": true,
        "singleQuote": false,
        "proseWrap": "preserve"
    },
    "nodeModulesDir": "auto"
}
